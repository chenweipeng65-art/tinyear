# =============================================================================
# 环境变量模板（示例值均为虚构，请勿用于生产）
# -----------------------------------------------------------------------------
# 使用方式：复制本文件为项目根目录的 `.env`，再按说明填入真实配置。
# 切勿将含真实密钥的 `.env` 提交到版本库。
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库（Prisma）
# -----------------------------------------------------------------------------
# SQLite 本地开发示例；生产可改为 PostgreSQL 等，格式见 Prisma 文档。
# Prisma 不会自动加载本文件，需在 prisma.config.ts 中 import "dotenv/config"
# 或使用带 env 加载的 CLI：https://pris.ly/d/connection-strings
DATABASE_URL="file:./dev.db"
# 生产示例（虚构）：postgresql://user:pass@localhost:5432/listening?schema=public

# -----------------------------------------------------------------------------
# HTTP API（Express，与 docs/后端集成方案 一致）
# -----------------------------------------------------------------------------
# 监听端口，默认 4741
API_PORT=4741
# 绑定地址，默认 0.0.0.0；仅本机可设为 127.0.0.1
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# 安全：身份证后 6 位等敏感字段的 HMAC 盐值（见 server/hashChildId.ts）
# -----------------------------------------------------------------------------
# 以下为本地开发常用占位；与代码内未设置 env 时的默认值一致。生产环境务必改为高强度随机串并保密。
ID_CARD_PEPPER=dev-m1-pepper

# -----------------------------------------------------------------------------
# 生产环境启动行为（可选）
# -----------------------------------------------------------------------------
# 设为任意非空值可在生产环境跳过启动时自动 seed（见 server/ensureSeedOnBoot.ts）
# SKIP_AUTO_SEED=1

# -----------------------------------------------------------------------------
# 对象存储（S3 兼容 API，预签名上传见 server/lib/s3UploadService.ts）
# -----------------------------------------------------------------------------
# 以下为占位示例，可对照 MinIO / 阿里云 OSS / 七牛 Kodo / AWS S3 等文档填写
S3_BUCKET_NAME=demo-app-uploads
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_ENDPOINT=https://s3.example-region.amazonaws.com
S3_REGION=us-east-1
# 对外访问文件时使用的 CDN 或桶域名根 URL（末尾不要多余斜杠也可，代码会处理）
S3_CDN=https://cdn.example.com
# 对象 key 命名模板（可选，默认见 s3UploadService）；支持 YYYY、MM、filename、file_ext、random 等占位符
# S3_OBJECT_NAME_STYLE=YYYY-MM-DD-HH-mm-ss-filename-file.file_ext
# 便于团队区分云厂商的标记（当前业务代码未读取，仅作部署文档用）：kodo | aws | minio | r2 等
S3_PROVIDER=

# -----------------------------------------------------------------------------
# 图片相关 AI（OpenAI 兼容接口见 ai/img-ai/model）
# -----------------------------------------------------------------------------
IMG_PROMPT_OPTIMISE_API_KEY=sk-example-img-key-replace-me
IMG_PROMPT_OPTIMISE_API_BASE_URL=https://api.example.com/v1
IMG_PROMPT_OPTIMISE_API_MODEL=qwen-vl-plus

# -----------------------------------------------------------------------------
# 文本相关 AI（教师分析、文案优化等，见 ai/txt-ai/model）
# -----------------------------------------------------------------------------
TXT_PROMPT_OPTIMISE_API_KEY=sk-example-txt-key-replace-me
TXT_PROMPT_OPTIMISE_API_BASE_URL=https://api.example.com/v1
TXT_PROMPT_OPTIMISE_API_MODEL=deepseek-v3

# -----------------------------------------------------------------------------
# 豆包（语音转写、实时助手等，见 server/routes）
# -----------------------------------------------------------------------------
DOUBAO_API_KEY=sk_doubao_example_replace_me
# 模型不设则使用默认模型

# -----------------------------------------------------------------------------
# 调试（可选，开发时启用更详细日志）
# -----------------------------------------------------------------------------
# 设为 1 时部分文本倾听链路输出调试信息（非 production 时部分逻辑默认也会更宽松）
# AI_LISTENING_TEXT_DEBUG=1
# 儿童作品图片分析链路调试
# AI_CHILD_ART_ANALYST_DEBUG=1
